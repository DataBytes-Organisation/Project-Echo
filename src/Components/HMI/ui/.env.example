# API host for the backend service.
# For local development, use 'localhost'.
# In Kubernetes, this is set automatically via the hmi-env ConfigMap to 'api-service'.
API_HOST=localhost

# Base URL for the frontend client (used for Stripe payment redirects).
# For local development, use 'http://localhost:8080'.
# On the live server, this should be set to the public URL of the site.
CLIENT_URL= 
